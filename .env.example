# Telegram
TELEGRAM_BOT_TOKEN=         # Token del bot (BotFather → /newbot)
GROUP_CHAT_ID=               # Chat ID del grupo (negativo, ej: -1001234567890). El bot lo imprime en logs al recibir el primer mensaje.

# LLM provider: "gemini" para desarrollo, "claude" para producción
LLM_PROVIDER=gemini

# Google Gemini (solo si LLM_PROVIDER=gemini)
GEMINI_API_KEY=              # APIs → Gemini

# Anthropic (solo si LLM_PROVIDER=claude)
ANTHROPIC_API_KEY=           # console.anthropic.com

# Postgres — Railway proporciona DATABASE_URL automáticamente al provisionar el plugin
# Formato: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://user:password@localhost:5432/chatbot_organizacion
DATABASE_PASSWORD= 